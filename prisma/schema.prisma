generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String              @id @default(uuid()) @db.Uuid
  email              String              @unique
  phoneNumber        String?             @unique
  firstName          String
  lastName           String
  localePreference   String              @default("en") @db.VarChar(10)
  patientProfile     Patient?
  sentMessages       Message[]           @relation("MessageSender")
  receivedMessages   Message[]           @relation("MessageRecipient")
  notifications      Notification[]
  proxyRelationships ProxyRelationship[] @relation("ProxyUser")
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

model Patient {
  id                       String              @id @default(uuid()) @db.Uuid
  userId                   String              @unique @db.Uuid
  dateOfBirth              DateTime?
  gender                   String?
  phoneNumber              String?
  emergencyContactName     String?
  emergencyContactPhone    String?
  allergies                String?
  currentMedications       String?
  prefersPushNotifications Boolean             @default(true)
  prefersSmsNotifications  Boolean             @default(false)
  prefersViberNotifications Boolean             @default(false)
  appointments             Appointment[]
  labResults               LabResult[]
  insurancePolicies        InsurancePolicy[]
  payments                 Payment[]
  incomingProxyDelegations ProxyRelationship[] @relation("ProxyPatient")
  user                     User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt                DateTime            @default(now())
  updatedAt                DateTime            @updatedAt
}

model Appointment {
  id             String      @id @default(uuid()) @db.Uuid
  patientId      String      @db.Uuid
  scheduledAt    DateTime
  status         AppointmentStatus @default(SCHEDULED)
  reasonForVisit String?
  providerName   String?
  location       String?
  notes          String?
  patient        Patient     @relation(fields: [patientId], references: [id], onDelete: Cascade)
  labResults     LabResult[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model LabResult {
  id            String              @id @default(uuid()) @db.Uuid
  patientId     String              @db.Uuid
  appointmentId String?             @db.Uuid
  testName      String
  resultValue   String?
  contextNote   String?
  status        LabResultStatus     @default(PENDING)
  category      LabResultCategory?
  loincCode     String?
  fhirId        String?             @unique
  sourceSystem  String?
  observedAt    DateTime?
  releasedAt    DateTime?
  attachmentUrl String?
  patient       Patient             @relation(fields: [patientId], references: [id], onDelete: Cascade)
  appointment   Appointment?        @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
}

model Message {
  id          String    @id @default(uuid()) @db.Uuid
  senderId    String    @db.Uuid
  recipientId String    @db.Uuid
  subject     String?
  body        String
  readAt      DateTime?
  sender      User      @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  recipient   User      @relation("MessageRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model ProxyRelationship {
  id               String    @id @default(uuid()) @db.Uuid
  proxyUserId      String    @db.Uuid
  patientId        String    @db.Uuid
  relationshipType ProxyRelationshipType
  consentDocumentUrl String? @db.VarChar(2048)
  status           ProxyRelationshipStatus @default(PENDING)
  reviewedAt       DateTime?
  isActive         Boolean   @default(true)
  startsAt         DateTime  @default(now())
  endsAt           DateTime?
  proxyUser        User      @relation("ProxyUser", fields: [proxyUserId], references: [id], onDelete: Cascade)
  patient          Patient   @relation("ProxyPatient", fields: [patientId], references: [id], onDelete: Cascade)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([proxyUserId, patientId], name: "unique_proxy_patient")
  @@index([isActive, patientId])
}

model InsurancePolicy {
  id             String    @id @default(uuid()) @db.Uuid
  patientId      String    @db.Uuid
  providerName   String
  policyNumber   String
  groupNumber    String?
  effectiveDate  DateTime?
  expirationDate DateTime?
  isPrimary      Boolean   @default(true)
  patient        Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([patientId, providerName, policyNumber], name: "unique_patient_policy")
}

model Notification {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @db.Uuid
  type        NotificationType
  title       String
  content     String
  isRead      Boolean   @default(false)
  deliveredAt DateTime?
  readAt      DateTime?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model OtpCode {
  id         String   @id @default(uuid()) @db.Uuid
  phoneNumber String
  otpHash    String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([phoneNumber, createdAt])
  @@index([phoneNumber, consumedAt, createdAt])
}

model Payment {
  id          String        @id @default(uuid()) @db.Uuid
  orderId     String        @unique
  patientId   String        @db.Uuid
  amount      Float
  description String
  status      PaymentStatus @default(PENDING)
  liqpayData  String?
  patient     Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([patientId])
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum LabResultStatus {
  PENDING
  COMPLETED
  REVIEWED
  PENDING_REVIEW
  AUTO_RELEASE
  RELEASED
}

enum LabResultCategory {
  ROUTINE
  SENSITIVE
}

enum ProxyRelationshipType {
  PARENT
  GUARDIAN
  CAREGIVER
  LEGAL_REPRESENTATIVE
}

enum ProxyRelationshipStatus {
  PENDING
  APPROVED
  REJECTED
}

enum NotificationType {
  APPOINTMENT
  LAB_RESULT
  MESSAGE
  REMINDER
  SYSTEM
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}
